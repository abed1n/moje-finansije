# Kopiraj u .env i prilagodi vrijednosti prije produkcijskog deploya.
POSTGRES_DB=pfm_db
POSTGRES_USER=pfm_user
POSTGRES_PASSWORD=promijeni-me
APP_PORT=8080
# Postavi na false u produkciji
SEED_DEMO_DATA=true

# Za produkciju generisi vlastite RSA kljuceve (kljucevi u repou su samo za demo):
#   openssl genrsa -out privateKey.pem 2048
#   openssl rsa -in privateKey.pem -pubout -out publicKey.pem
# pa ih mountaj u kontejner i otkomentarisi:
# JWT_PRIVATE_KEY_LOCATION=/app/keys/privateKey.pem
# JWT_PUBLIC_KEY_LOCATION=/app/keys/publicKey.pem
