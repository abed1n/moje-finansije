# Kopiraj u .env i popuni vrijednosti prije javnog deploya.
# Docker compose ucitava .env automatski.

# --- Baza ---
POSTGRES_DB=pfm_db
POSTGRES_USER=pfm_user
POSTGRES_PASSWORD=promijeni-me-obavezno
APP_PORT=8080

# Iskljuci demo podatke na javnoj instanci (demo/admin nalozi se ne kreiraju)
SEED_DEMO_DATA=false

# --- HTTPS / adresa ---
# Samo domen (bez https://) - koristi ga Caddy za SSL sertifikat.
APP_DOMAIN=tvoj-domen.me
# Puna javna adresa aplikacije (koristi se za linkove u email porukama).
APP_BASE_URL=https://tvoj-domen.me
# Ukljuci Secure flag na refresh kolacicu - obavezno kad si iza HTTPS-a.
COOKIE_SECURE=true
# Iza Caddy-ja app ne treba da bude javno dostupan - vezi ga samo za lokalni interfejs.
APP_BIND=127.0.0.1

# --- JWT kljucevi ---
# Kljucevi u repou su SAMO za demo i javni su na GitHubu. Za javni deploy
# generisi vlastite pa ih mountaj (otkomentarisi volume u docker-compose.yml):
#   openssl genrsa -out keys/privateKey.pem 2048
#   openssl rsa -in keys/privateKey.pem -pubout -out keys/publicKey.pem
JWT_PRIVATE_KEY_LOCATION=/app/keys/privateKey.pem
JWT_PUBLIC_KEY_LOCATION=/app/keys/publicKey.pem

# --- Google prijava ---
# OAuth 2.0 Web Client ID iz Google Cloud konzole. Ako ostane prazno,
# dugme "Nastavi putem Google naloga" se ne prikazuje.
GOOGLE_CLIENT_ID=

# --- Slanje emaila (verifikacija adrese, reset lozinke) ---
# Za pravo slanje postavi MAILER_MOCK=false i SMTP podatke.
# Primjer za Gmail (potreban "app password", ne obicna lozinka naloga):
MAILER_MOCK=false
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
# STARTTLS na portu 587 (Gmail). Ostavi REQUIRED osim ako server izricito trazi drugacije.
MAILER_TLS=REQUIRED
MAILER_USERNAME=tvoj-email@gmail.com
MAILER_PASSWORD=app-password-iz-google-naloga
MAILER_FROM=Moje finansije <tvoj-email@gmail.com>
